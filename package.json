{
  "name": "zwavejs2homey-workspace",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "co.lazylabs.zwavejs2homey"
  ],
  "scripts": {
    "build": "npm run build -w @zwavejs2homey/compiler && npm run build -w @zwavejs2homey/core && npm run build -w @zwavejs2homey/tui && npm run build -w co.lazylabs.zwavejs2homey",
    "build:core": "npm run build -w @zwavejs2homey/core",
    "build:homey": "npm run build -w co.lazylabs.zwavejs2homey",
    "check": "npm run format:check && npm run lint && npm run test -w @zwavejs2homey/compiler && npm run test -w @zwavejs2homey/core && npm run test -w @zwavejs2homey/tui && npm run build -w co.lazylabs.zwavejs2homey",
    "lint": "npm run lint -w co.lazylabs.zwavejs2homey",
    "zwjs:inspect": "node tools/zwjs-inspect.mjs",
    "compiler:tui": "npm run build -w @zwavejs2homey/tui && node packages/tui/dist/cli.js",
    "compiler:inspect": "node tools/homey-compile-inspect.mjs",
    "compiler:inspect-live": "node tools/homey-compile-inspect-live.mjs",
    "compiler:validate-live": "node tools/homey-compile-validate-live.mjs",
    "compiler:baseline": "node tools/homey-compile-baseline.mjs",
    "compiler:simulate": "node tools/homey-compile-simulate.mjs",
    "compiler:build": "node tools/homey-compile-build.mjs",
    "compiler:homey-vocabulary": "node tools/homey-authoring-vocabulary-build.mjs",
    "compiler:vocabulary": "npm run compiler:homey-vocabulary",
    "compiler:bench": "node tools/homey-compile-bench.mjs",
    "ha-import:extract": "node tools/ha-import-extract.mjs",
    "ha-import:report": "node tools/ha-import-report.mjs",
    "catalog": "node tools/catalog-tool.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.6.2"
  }
}
