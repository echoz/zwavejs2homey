{
  "name": "zwavejs2homey-workspace",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run homey:vendor:sync && npm --prefix co.lazylabs.zwavejs2homey install",
    "build": "npm run build -w @zwavejs2homey/compiler && npm run build -w @zwavejs2homey/core && npm run build -w @zwavejs2homey/tui && npm run compiler:build:bundled && npm run homey:vendor:sync && npm --prefix co.lazylabs.zwavejs2homey run build",
    "build:core": "npm run build -w @zwavejs2homey/core",
    "build:homey": "npm run compiler:build:bundled && npm run homey:vendor:sync && npm --prefix co.lazylabs.zwavejs2homey run build",
    "homey:runtime-api:smoke": "node tools/homey-runtime-api-smoke.mjs",
    "homey:support-bundle": "node tools/homey-support-bundle.mjs",
    "homey:vendor:sync": "node tools/sync-homey-vendor-packages.mjs",
    "check": "npm run format:check && npm run lint && npm run policy:guard && npm run test -w @zwavejs2homey/compiler && npm run test -w @zwavejs2homey/core && npm run test -w @zwavejs2homey/tui && npm --prefix co.lazylabs.zwavejs2homey run test",
    "lint": "npm --prefix co.lazylabs.zwavejs2homey run lint",
    "zwjs:inspect": "node tools/zwjs-inspect.mjs",
    "compiler:tui": "npm run build -w @zwavejs2homey/tui && node packages/tui/dist/cli.js",
    "compiler:inspect": "node tools/homey-compile-inspect.mjs",
    "compiler:inspect-live": "node tools/homey-compile-inspect-live.mjs",
    "compiler:validate-live": "node tools/homey-compile-validate-live.mjs",
    "compiler:baseline": "node tools/homey-compile-baseline.mjs",
    "compiler:simulate": "node tools/homey-compile-simulate.mjs",
    "compiler:build": "node tools/homey-compile-build.mjs",
    "compiler:build:bundled": "node tools/homey-build-bundled-compiled-artifact.mjs",
    "compiler:homey-vocabulary": "node tools/homey-authoring-vocabulary-build.mjs",
    "compiler:vocabulary": "npm run compiler:homey-vocabulary",
    "policy:guard": "node tools/hardcoding-policy-guard.mjs",
    "compiler:bench": "node tools/homey-compile-bench.mjs",
    "ha-import:extract": "node tools/ha-import-extract.mjs",
    "ha-import:report": "node tools/ha-import-report.mjs",
    "catalog": "node tools/catalog-tool.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.6.2"
  }
}
