{
  "id": "co.lazylabs.zwavejs2homey",
  "version": "1.0.0",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "platforms": ["local"],
  "name": {
    "en": "zwavejs2homey"
  },
  "description": {
    "en": "Z-Wave JS Bridge"
  },
  "brandColor": "#2484bf",
  "category": ["tools"],
  "permissions": [],
  "api": {
    "getRuntimeBridges": {
      "method": "GET",
      "path": "/runtime/bridges"
    },
    "getRuntimeDiagnostics": {
      "method": "GET",
      "path": "/runtime/diagnostics"
    },
    "getRuntimeSupportBundle": {
      "method": "GET",
      "path": "/runtime/support-bundle"
    },
    "getRecommendationActionQueue": {
      "method": "GET",
      "path": "/runtime/recommendations"
    },
    "executeRecommendationAction": {
      "method": "POST",
      "path": "/runtime/recommendations/execute"
    },
    "executeRecommendationActions": {
      "method": "POST",
      "path": "/runtime/recommendations/execute-batch"
    },
    "getProfileExtensions": {
      "method": "GET",
      "path": "/runtime/extensions"
    },
    "getProfileExtensionRead": {
      "method": "GET",
      "path": "/runtime/extensions/read"
    },
    "executeProfileExtensionAction": {
      "method": "POST",
      "path": "/runtime/extensions/execute"
    }
  },
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Jeremy Foo",
    "email": "f6fmxkbhnh@privaterelay.appleid.com"
  }
}
